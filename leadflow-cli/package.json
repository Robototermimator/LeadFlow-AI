{
  "name": "leadflow-cli-v2",
  "version": "2.1.0",
  "description": "LeadFlow CLI v2 — AI Client Acquisition System (offline)",
  "license": "MIT",
  "bin": {
    "leadflow": "./index.js"
  },
  "type": "commonjs",
  "scripts": {
    "start": "node index.js",
    "sample": "node index.js generate --niche dentists --location \"Cape Town\" --service \"website redesign\" --count 5 --mode deep --output examples/sample-output.csv",
    "build:exe": "pkg . --targets node18-win-x64,node18-macos-x64,node18-linux-x64 --out-path dist",
    "build:win": "pkg . --targets node18-win-x64 --out-path dist",
    "build:mac": "pkg . --targets node18-macos-x64 --out-path dist",
    "build:linux": "pkg . --targets node18-linux-x64 --out-path dist"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "pkg": {
    "targets": [
      "node18-win-x64",
      "node18-macos-x64",
      "node18-linux-x64"
    ],
    "scripts": [
      "src/**/*.js",
      "index.js"
    ],
    "assets": [
      "data/*.json",
      "examples/*",
      "sales-assets/*",
      "README.md",
      "LICENSE",
      ".env.example"
    ],
    "outputPath": "dist"
  }
}
