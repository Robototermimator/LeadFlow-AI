<%- include('partials/header', { title, user }) %>
<%- include('partials/app-nav') %>
<section class="page-head"><h1>Run History</h1><p>See all lead generation runs and criteria.</p></section>
<section class="card">
  <% if (!runs.length) { %>
    <p class="muted">No runs found.</p>
  <% } else { %>
    <div class="table-wrap"><table><thead><tr><th>Date</th><th>Criteria</th><th>Tone</th><th>Status</th><th>Lead Count</th><th>Link</th></tr></thead><tbody>
      <% runs.forEach(run => { %>
        <tr>
          <td><%= run.created_at %></td>
          <td><%= run.niche %> | <%= run.location %> | <%= run.target_business_type %></td>
          <td><%= run.tone %></td>
          <td><%= run.status %></td>
          <td><%= run.leads_generated %></td>
          <td><a href="/app/leads">View Leads</a></td>
        </tr>
      <% }) %>
    </tbody></table></div>
  <% } %>
</section>
<%- include('partials/footer') %>
